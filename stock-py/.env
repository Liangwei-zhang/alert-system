# Local development overrides for running public-api on :3000
ENVIRONMENT=development
DEBUG=True
PROJECT_NAME=StockPy API
LOG_LEVEL=INFO

# Run local public API at port 3000
HOST=0.0.0.0
PORT=3000
PUBLIC_API_HOST=0.0.0.0
PUBLIC_API_PORT=3000
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8001
ALLOWED_ORIGINS=["*"]

# Match compose postgres credentials
DATABASE_URL=postgresql+asyncpg://stock_py:stock_py@localhost:5432/stock_py
DATABASE_POOL_MODE=direct
PGBOUNCER_ADMIN_URL=
REDIS_URL=redis://localhost:6379/0

# Keep token signature compatible with running admin-api container
SECRET_KEY=dev-stock-py-secret-key-change-before-shared-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
TRADE_LINK_SECRET=dev-stock-py-trade-link-secret
WEB_PUSH_PUBLIC_KEY=BLJp93vB9MONAhv2HBWaa12tVzag7FA_kagE-bp2WODzDh5JbuI3rfT2rwfnxz324khIncC6cyl6gJgJzeZeKrQ
WEB_PUSH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgbQJJKioG9Xo9G6Px\nl7ywuHRPKvis+6GH6hlLz/Qjcc6hRANCAASyafd7wfTDjQIb9hwVmmtdrVc2oOxQ\nP5GoBPm6dljg8w4eSW7iN6309q8H58c99uJISJ3AunMpeoCYCc3mXiq0\n-----END PRIVATE KEY-----
WEB_PUSH_SUBJECT=mailto:admin@stockpy.com

# Keep local runtime lightweight
EVENT_BROKER_BACKEND=redis
EVENT_BROKER_STREAM_NAME=stock-py.events
OBJECT_STORAGE_BACKEND=local
ANALYTICS_BACKEND=local
