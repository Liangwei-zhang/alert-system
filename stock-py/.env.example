# Project
ENVIRONMENT=development
PROJECT_NAME=Stock API
DEBUG=True
VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000
PUBLIC_API_HOST=0.0.0.0
PUBLIC_API_PORT=8000
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8001
NGINX_HOST_PORT=8080

# CORS
ALLOWED_ORIGINS=["*"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stock
DATABASE_POOL_MODE=direct
PGBOUNCER_ADMIN_URL=
POSTGRES_HOST_PORT=5432
PGBOUNCER_HOST_PORT=6432
# PgBouncer transaction pooling example:
# DATABASE_URL=postgresql+asyncpg://user:password@pgbouncer:6432/stock?prepared_statement_cache_size=0
# PGBOUNCER_ADMIN_URL=postgresql://user:password@pgbouncer:6432/pgbouncer

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAXMEMORY=768mb
REDIS_MAXMEMORY_POLICY=volatile-ttl
REDIS_HOST_PORT=6379

# Event broker
EVENT_BROKER_BACKEND=redis
EVENT_BROKER_STREAM_NAME=stock-py.events
EVENT_BROKER_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EVENT_BROKER_KAFKA_TOPIC=stock-py.events
EVENT_BROKER_KAFKA_AUTO_OFFSET_RESET=earliest
EVENT_BROKER_GROUP_NAME=stock-py.dispatchers
KAFKA_HOST_PORT=9092

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
IDEMPOTENCY_TTL_SECONDS=86400

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Scheduler
SCHEDULER_HEARTBEAT_SECONDS=30

# Logging
LOG_LEVEL=INFO

# TradingAgents
TRADINGAGENTS_WEBHOOK_SECRET=
TRADE_LINK_SECRET=change-me-trade-link-secret
INTERNAL_SIGNAL_INGEST_SECRET=

# Web Push
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@stockpy.com

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=True
SMTP_TIMEOUT_SECONDS=10
EMAIL_FROM_ADDRESS=noreply@stockpy.local
EMAIL_FROM_NAME=StockPy

# Object storage
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_ROOT=.local/object-storage
OBJECT_STORAGE_BUCKET=stock-py
OBJECT_STORAGE_PREFIX=
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=True
MINIO_CONSOLE_HOST_PORT=9001
MINIO_API_HOST_PORT=9002

# Analytics backend
ANALYTICS_BACKEND=local
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=stock
CLICKHOUSE_USERNAME=stock
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=False
CLICKHOUSE_VERIFY_TLS=True
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=10
CLICKHOUSE_TABLE_TTL_DAYS=180
CLICKHOUSE_HTTP_HOST_PORT=8123
CLICKHOUSE_NATIVE_HOST_PORT=9000

# Retention partition archive
RETENTION_PARTITION_ARCHIVE_ENABLED=True
RETENTION_PARTITION_ARCHIVE_MAX_PARTITIONS_PER_RUN=6
RETENTION_NOTIFICATION_PARTITION_RETENTION_DAYS=90
RETENTION_RECEIPT_ARCHIVE_PARTITION_RETENTION_DAYS=180
RETENTION_EVENT_OUTBOX_PARTITION_RETENTION_DAYS=90

# Runtime monitoring / alert thresholds
RUNTIME_METRICS_WINDOW_MINUTES=15
RUNTIME_ALERT_BROKER_LAG_THRESHOLD=200
RUNTIME_ALERT_PGBOUNCER_WAITING_CLIENTS_THRESHOLD=10
RUNTIME_ALERT_REDIS_MEMORY_PERCENT_THRESHOLD=85
RUNTIME_ALERT_CLICKHOUSE_WRITE_FAILURE_RATE_THRESHOLD=5
RUNTIME_ALERT_OBJECT_STORAGE_ARCHIVE_FAILURE_RATE_THRESHOLD=5

# QA / Locust load testing
LOAD_TEST_HOST=http://localhost:8000
LOAD_TEST_ACCESS_TOKEN=
LOAD_TEST_REFRESH_TOKEN=
LOAD_TEST_AUTH_EMAIL=loadtest@example.com
LOAD_TEST_NOTIFICATION_LIMIT=20
LOAD_TEST_TRADE_ID=
LOAD_TEST_TRADE_TOKEN=
LOAD_TEST_ENABLE_TRADE_MUTATIONS=false
LOAD_TEST_TRADINGAGENTS_TICKER=AAPL
LOAD_TEST_TRADINGAGENTS_ANALYSTS=alpha,beta
LOAD_TEST_TRADINGAGENTS_TRIGGER_TYPE=load_test
LOAD_TEST_TRADINGAGENTS_TRIGGER_SOURCE=locust